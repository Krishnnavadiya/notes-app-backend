# --- Server ---
PORT=3000
NODE_ENV=development

# --- Auth ---
# IMPORTANT: generate a strong secret in production, e.g. `openssl rand -hex 64`
JWT_SECRET=replace-me-with-a-strong-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Database ---
# Leave DATABASE_URL empty to use the file-based SQLite at SQLITE_PATH (great for local dev).
# Set DATABASE_URL to a Postgres connection string for production.
DATABASE_URL=
SQLITE_PATH=./data/notes.db

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# --- About endpoint ---
OWNER_NAME=Your Name
OWNER_EMAIL=you@example.com
